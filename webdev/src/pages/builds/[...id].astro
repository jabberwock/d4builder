---
import Layout from '@/layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

export function getStaticPaths() {
  const index = JSON.parse(
    readFileSync(resolve('public/data/builds_index.json'), 'utf-8')
  ) as { builds: { id: string }[] };
  return index.builds.map((b) => ({ params: { id: b.id } }));
}

const { id } = Astro.params;

type SkillUpgrade = { name: string; enhanced: string; morph: string };
type GearItem = {
  rarity: string;
  unique_id?: string;
  _optimizer_name?: string;
  aspect_id?: string;
  base_item_type?: string;
};
type Gear = Record<string, GearItem>;
type AspectRec = { slot: string; aspect_name: string; max_value: number };
type Tempers = Record<string, string>;
type Gems = Record<string, string>;
type ParagonBoard = { board: string; glyph: string };
type RunePair = { ritual: string; invocation: string; score: number };
type NightmareDungeon = { name: string; zone: string; region: string; aspect: string };
type Mercenary = { primary: string; reason: string };

type Build = {
  id: string;
  build_name: string;
  class: string;
  purpose: string;
  purpose_label: string;
  tier: string;
  build_score: number;
  global_rank: number;
  season: string;
  patch: string;
  specialization: string;
  skill_bar: string[];
  skill_bar_rank: number;
  skill_upgrades: SkillUpgrade[];
  passives: string[];
  passive_rank: number;
  key_passive: string;
  gear: Gear;
  aspects_recommended: AspectRec[];
  tempers_recommended: Tempers;
  gems_recommended: Gems;
  paragon_boards: ParagonBoard[];
  rune_pair_1: RunePair;
  rune_pair_2: RunePair;
  mercenary: Mercenary;
  nightmare_dungeons: NightmareDungeon[];
  score_breakdown: Record<string, number>;
  sources: Record<string, string>;
};

const build: Build = JSON.parse(
  readFileSync(resolve(`public/data/builds/${id}.json`), 'utf-8')
);

const classSlug = build.class.toLowerCase();

const tierColor: Record<string, string> = {
  S: 'var(--color-tier-s)',
  A: 'var(--color-tier-a)',
  B: 'var(--color-tier-b)',
  C: 'var(--color-tier-c)',
};

const GEAR_SLOTS = ['Helm', 'Chest', 'Gloves', 'Legs', 'Boots', 'Weapon', 'Offhand', 'Ring', 'Amulet'];

function cap(s: string) {
  return s ? s.charAt(0).toUpperCase() + s.slice(1) : s;
}

// Mercenary reason sometimes has "Name — description" format, split for display
function parseMercenaryReason(reason: string): { name: string; detail: string } {
  const dashIdx = reason.indexOf('\u2014');
  if (dashIdx > -1) {
    return {
      name: reason.slice(0, dashIdx).trim(),
      detail: reason.slice(dashIdx + 1).trim(),
    };
  }
  return { name: '', detail: reason };
}
---

<Layout
  title={`${build.purpose_label} ${build.class} — D4Builder`}
  description={`${build.purpose_label} ${build.class} build for Season 12. Tier ${build.tier}, rank #${build.global_rank}. Key passive: ${build.key_passive}${build.specialization ? ` · ${build.specialization}` : ''}. All data sourced from optimizer.`}
>
  <main class={`build-detail build-detail--${classSlug}`}>
    <div class="container">

      <!-- Breadcrumb nav -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">All Classes</a>
        <span aria-hidden="true" class="sep">/</span>
        <a href={`/class/${classSlug}`}>{build.class}</a>
        <span aria-hidden="true" class="sep">/</span>
        <span aria-current="page">{build.purpose_label}</span>
      </nav>

      <!-- Build header -->
      <header class="build-header">
        <div class={`class-stripe class-stripe--${classSlug}`} aria-hidden="true"></div>
        <div class="build-header__content">
          <div class="build-header__title-row">
            <h1 class="build-header__h1">{build.purpose_label} {build.class}</h1>
            <span
              class={`tier-badge tier-badge--${build.tier.toLowerCase()}`}
              aria-label={`Tier ${build.tier}`}
            >
              {build.tier}
            </span>
          </div>
          <div class="build-header__meta">
            <span>Rank #{build.global_rank} of 28</span>
            <span class="meta-sep">·</span>
            <span>{Math.round(build.build_score).toLocaleString('en-US')} pts</span>
            <span class="meta-sep">·</span>
            <span>{build.season}</span>
            <span class="meta-sep">·</span>
            <span>Patch {build.patch}</span>
          </div>
          {build.specialization && (
            <div class="spec-pill">{build.specialization}</div>
          )}
        </div>
      </header>

      <!-- Quick summary row -->
      <div class="summary-row">
        <div class="summary-stat">
          <span class="summary-stat__label">Key Passive</span>
          <span class="summary-stat__value">{build.key_passive}</span>
        </div>
        <div class="summary-stat">
          <span class="summary-stat__label">Skills</span>
          <span class="summary-stat__value">{build.skill_bar.join(' · ')}</span>
        </div>
      </div>

      <!-- Skills -->
      <section class="section" id="skills">
        <h2 class="section__title">Skill Bar</h2>
        <div class="skill-list">
          {build.skill_upgrades.map((su) => (
            <div class="skill-row">
              <div class="skill-row__name">{su.name}</div>
              <div class="skill-row__path">
                <span class="upgrade enhanced">{su.enhanced}</span>
                <span class="upgrade-sep" aria-hidden="true">→</span>
                <span class="upgrade morph">{su.morph}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Passives -->
      <section class="section" id="passives">
        <h2 class="section__title">Passives</h2>
        <div class="passive-chips">
          {build.passives.map((p) => (
            <span class="passive-chip">{p}</span>
          ))}
        </div>
        <div class="key-passive-block">
          <span class="key-passive-block__label">Key Passive</span>
          <span class="key-passive-block__name">{build.key_passive}</span>
        </div>
      </section>

      <!-- Gear -->
      <section class="section" id="gear">
        <h2 class="section__title">Gear</h2>
        <div class="gear-table">
          {GEAR_SLOTS.filter((slot) => build.gear[slot]).map((slot) => {
            const item = build.gear[slot];
            let name: string;
            if (item._optimizer_name) {
              name = item._optimizer_name;
            } else if (item.rarity === 'legendary' && item.base_item_type && item.aspect_id) {
              name = `${item.base_item_type} — ${item.aspect_id.replace(/_/g, ' ')}`;
            } else {
              name = '—';
            }
            return (
              <div class="gear-row">
                <span class="gear-row__slot">{slot}</span>
                <span class={`gear-row__name gear-row__name--${item.rarity}`}>{name}</span>
                <span class="gear-row__rarity">{cap(item.rarity)}</span>
              </div>
            );
          })}
        </div>
      </section>

      <!-- Aspects -->
      {build.aspects_recommended?.length > 0 && (
        <section class="section" id="aspects">
          <h2 class="section__title">Aspects</h2>
          <div class="aspects-list">
            {build.aspects_recommended.map((a) => (
              <div class="aspect-row">
                <span class="aspect-row__slot">{a.slot}</span>
                <span class="aspect-row__name">{a.aspect_name}</span>
                {a.max_value != null && (
                  <span class="aspect-row__value">max {a.max_value}</span>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Tempers + Gems -->
      {((build.tempers_recommended && Object.keys(build.tempers_recommended).length > 0) ||
        (build.gems_recommended && Object.keys(build.gems_recommended).length > 0)) && (
        <div class="two-col">
          {build.tempers_recommended && Object.keys(build.tempers_recommended).length > 0 && (
            <section class="section" id="tempers">
              <h2 class="section__title">Tempers</h2>
              <dl class="kv-list">
                {Object.entries(build.tempers_recommended).map(([k, v]) => (
                  <>
                    <dt>{cap(k)}</dt>
                    <dd>{v}</dd>
                  </>
                ))}
              </dl>
            </section>
          )}
          {build.gems_recommended && Object.keys(build.gems_recommended).length > 0 && (
            <section class="section" id="gems">
              <h2 class="section__title">Gems</h2>
              <dl class="kv-list">
                {Object.entries(build.gems_recommended).map(([k, v]) => (
                  <>
                    <dt>{cap(k)}</dt>
                    <dd>{v}</dd>
                  </>
                ))}
              </dl>
            </section>
          )}
        </div>
      )}

      <!-- Paragon -->
      {build.paragon_boards?.length > 0 && (
        <section class="section" id="paragon">
          <h2 class="section__title">Paragon Boards</h2>
          <div class="paragon-list">
            {build.paragon_boards.map((pb, i) => (
              <div class="paragon-row">
                <span class="paragon-row__num">{i + 1}</span>
                <span class="paragon-row__board">{pb.board}</span>
                <span class="paragon-row__glyph">{pb.glyph}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Runes -->
      {(build.rune_pair_1 || build.rune_pair_2) && (
        <section class="section" id="runes">
          <h2 class="section__title">Runes</h2>
          <div class="rune-pairs">
            {[build.rune_pair_1, build.rune_pair_2].filter(Boolean).map((rp, i) => (
              <div class="rune-pair">
                <span class="rune-pair__label">Pair {i + 1}</span>
                <div class="rune-pair__runes">
                  <span class="rune rune--ritual">{rp.ritual}</span>
                  <span class="rune-plus" aria-hidden="true">+</span>
                  <span class="rune rune--invocation">{rp.invocation}</span>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Mercenary -->
      {build.mercenary && (
        <section class="section" id="mercenary">
          <h2 class="section__title">Mercenary</h2>
          {(() => {
            const parsed = parseMercenaryReason(build.mercenary.reason);
            return (
              <div class="mercenary-card">
                <div class="mercenary-card__name">{build.mercenary.primary}</div>
                {parsed.name && <div class="mercenary-card__specialization">{parsed.name}</div>}
                <p class="mercenary-card__detail">{parsed.detail || build.mercenary.reason}</p>
              </div>
            );
          })()}
        </section>
      )}

      <!-- Nightmare Dungeons -->
      {build.nightmare_dungeons?.length > 0 && (
        <section class="section" id="dungeons">
          <h2 class="section__title">Nightmare Dungeons</h2>
          <p class="section__sub">Farm these to target aspect drops</p>
          <div class="dungeon-list">
            {build.nightmare_dungeons.map((d) => (
              <div class="dungeon-row">
                <div class="dungeon-row__name">{d.name}</div>
                <div class="dungeon-row__meta">
                  <span class="dungeon-zone">{d.zone}</span>
                  {d.aspect && (
                    <span class="dungeon-aspect">→ {d.aspect}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Score Breakdown (collapsible) -->
      {build.score_breakdown && Object.keys(build.score_breakdown).length > 0 && (
        <section class="section section--score-breakdown" id="score-breakdown">
          <details>
            <summary class="score-breakdown__summary">Score Breakdown</summary>
            <dl class="score-breakdown__list">
              {Object.entries(build.score_breakdown).sort(([,a],[,b]) => b - a).map(([k, v]) => (
                <>
                  <dt>{k.replace(/_/g, ' ')}</dt>
                  <dd>{Math.round(v as number).toLocaleString('en-US')}</dd>
                </>
              ))}
            </dl>
          </details>
        </section>
      )}

      <!-- Sources -->
      <section class="section section--sources" id="sources">
        <h2 class="section__title">Data Sources</h2>
        <dl class="sources-list">
          {Object.entries(build.sources).map(([k, v]) => (
            <>
              <dt>{k.replace(/_/g, ' ')}</dt>
              <dd>{v}</dd>
            </>
          ))}
        </dl>
      </section>

    </div>
  </main>
</Layout>

<style>
  .build-detail {
    min-height: 100vh;
    padding: var(--space-lg) 0 var(--space-2xl);
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--color-primary); }
  .sep { color: var(--color-text-muted); }
  .breadcrumb span[aria-current] { color: var(--color-text-secondary); }

  /* Build header */
  .build-header {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    margin-bottom: var(--space-xl);
  }

  .class-stripe {
    width: 4px;
    min-height: 80px;
    border-radius: 2px;
    flex-shrink: 0;
    align-self: stretch;
  }

  .class-stripe--barbarian  { background: var(--class-barbarian); }
  .class-stripe--druid       { background: var(--class-druid); }
  .class-stripe--necromancer { background: var(--class-necromancer); }
  .class-stripe--paladin     { background: var(--class-paladin); }
  .class-stripe--rogue       { background: var(--class-rogue); }
  .class-stripe--sorcerer    { background: var(--class-sorcerer); }
  .class-stripe--spiritborn  { background: var(--class-spiritborn); }

  .build-header__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .build-header__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .build-header__h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    margin: 0;
  }

  .tier-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 6px;
    font-size: var(--font-size-xl);
    font-weight: 800;
    flex-shrink: 0;
  }

  .tier-badge--s { background: rgba(212,175,55,0.15);  color: var(--color-tier-s); border: 1px solid rgba(212,175,55,0.3); }
  .tier-badge--a { background: rgba(34,197,94,0.12);   color: var(--color-tier-a); border: 1px solid rgba(34,197,94,0.25); }
  .tier-badge--b { background: rgba(59,130,246,0.12);  color: var(--color-tier-b); border: 1px solid rgba(59,130,246,0.25); }
  .tier-badge--c { background: rgba(156,163,175,0.10); color: var(--color-tier-c); border: 1px solid rgba(156,163,175,0.2); }

  .build-header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .meta-sep { color: var(--color-text-muted); }

  .spec-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px var(--space-sm);
    background: rgba(216, 165, 0, 0.08);
    border: 1px solid rgba(216, 165, 0, 0.2);
    border-radius: 4px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-primary);
    width: fit-content;
  }

  /* Summary row */
  .summary-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
    margin-bottom: var(--space-2xl);
  }

  .summary-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .summary-stat__label {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .summary-stat__value {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Sections */
  .section {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .section__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .section__sub {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-md);
  }

  /* Skill list */
  .skill-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .skill-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-secondary);
    border-radius: 6px;
    flex-wrap: wrap;
  }

  @media (min-width: 640px) {
    .skill-row { flex-wrap: nowrap; }
  }

  .skill-row__name {
    font-weight: 600;
    font-size: var(--font-size-sm);
    min-width: 130px;
    flex-shrink: 0;
  }

  .skill-row__path {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .upgrade {
    font-size: var(--font-size-xs);
    padding: 2px var(--space-sm);
    border-radius: 3px;
  }

  .upgrade.enhanced {
    background: rgba(79, 195, 247, 0.1);
    border: 1px solid rgba(79, 195, 247, 0.25);
    color: #67d5f7;
  }

  .upgrade.morph {
    background: rgba(216, 165, 0, 0.1);
    border: 1px solid rgba(216, 165, 0, 0.25);
    color: var(--color-primary);
  }

  .upgrade-sep {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
  }

  /* Passives */
  .passive-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .passive-chip {
    font-size: var(--font-size-sm);
    padding: 4px var(--space-md);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text);
  }

  .key-passive-block {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: rgba(216, 165, 0, 0.06);
    border: 1px solid rgba(216, 165, 0, 0.2);
    border-radius: 6px;
    width: fit-content;
    max-width: 100%;
  }

  .key-passive-block__label {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .key-passive-block__name {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Gear table */
  .gear-table {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .gear-row {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border-subtle);
    background: var(--color-bg-card);
  }

  .gear-row:last-child { border-bottom: none; }
  .gear-row:nth-child(even) { background: var(--color-bg-secondary); }

  .gear-row__slot {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .gear-row__name {
    font-size: var(--font-size-sm);
    font-weight: 600;
  }

  .gear-row__name--unique   { color: #e0903a; }
  .gear-row__name--legendary { color: var(--color-primary); }
  .gear-row__name--rare     { color: #c8b400; }

  .gear-row__rarity {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  /* Aspects */
  .aspects-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .aspect-row {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-secondary);
    border-radius: 4px;
  }

  .aspect-row__slot {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .aspect-row__name {
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  .aspect-row__value {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Two column */
  .two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .two-col {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .two-col .section { border-bottom: none; padding-bottom: 0; }
  }

  /* KV list */
  .kv-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-md);
  }

  .kv-list dt {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .kv-list dd {
    font-size: var(--font-size-sm);
    margin: 0;
    color: var(--color-text);
  }

  /* Paragon */
  .paragon-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .paragon-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-secondary);
    border-radius: 4px;
  }

  .paragon-row__num {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    min-width: 16px;
    flex-shrink: 0;
  }

  .paragon-row__board {
    flex: 1;
    font-size: var(--font-size-sm);
