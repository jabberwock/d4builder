---
import Layout from '@/layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

type BuildSummary = {
  id: string;
  class: string;
  tier: string;
  build_score: number;
  global_rank: number;
  purpose_label: string;
  key_passive: string;
  specialization: string;
  skill_bar_summary: string[];
};

const index = JSON.parse(
  readFileSync(resolve('public/data/builds_index.json'), 'utf-8')
) as { builds: BuildSummary[] };

const classes = ['Barbarian', 'Druid', 'Necromancer', 'Paladin', 'Rogue', 'Sorcerer', 'Spiritborn'] as const;

// Per class: find the best-ranked build (lowest global_rank) and count total builds
type ClassSummary = {
  bestBuild: BuildSummary;
  buildCount: number;
};
const classSummaries: Record<string, ClassSummary> = {};
for (const cls of classes) {
  const builds = index.builds.filter((b) => b.class === cls);
  const best = builds.reduce((a, b) => a.global_rank < b.global_rank ? a : b);
  classSummaries[cls] = { bestBuild: best, buildCount: builds.length };
}

const tierColor: Record<string, string> = {
  S: 'var(--color-tier-s)',
  A: 'var(--color-tier-a)',
  B: 'var(--color-tier-b)',
  C: 'var(--color-tier-c)',
};
---

<Layout title="D4Builder — Choose Your Class">
  <main class="home">
    <div class="container home__inner">

      <header class="hero">
        <div class="hero__wordmark">D4Builder</div>
        <h1 class="hero__title">Pick your class.<br/>Find your build.</h1>
        <p class="hero__sub">Fast, sourced Diablo 4 builds for returning seasonal players.<br class="desktop-only"/>Every number traced to the optimizer — no guesswork.</p>
      </header>

      <section class="class-picker" aria-label="Choose a class">
        <div class="class-grid">
          {classes.map((cls) => {
            const slug = cls.toLowerCase();
            const { bestBuild, buildCount } = classSummaries[cls];
            const tier = bestBuild.tier;
            return (
              <a
                href={`/class/${slug}`}
                class={`class-tile class-tile--${slug}`}
                aria-label={`${cls} builds`}
              >
                <div class="class-tile__accent" aria-hidden="true"></div>
                <div class="class-tile__body">
                  <div class="class-tile__top">
                    <h2 class="class-tile__name">{cls}</h2>
                    <span
                      class="tier-badge"
                      style={`color: ${tierColor[tier] ?? '#999'}`}
                      title={`Best build: Tier ${tier}`}
                    >
                      {tier}
                    </span>
                  </div>
                  <div class="class-tile__summary">
                    <span class="class-tile__summary-line">Best: {tier}-tier · Rank #{bestBuild.global_rank}</span>
                    <span class="class-tile__summary-line">Key: {bestBuild.key_passive}{bestBuild.specialization ? ` · ${bestBuild.specialization}` : ''}</span>
                  </div>
                  <div class="class-tile__footer">
                    <span class="class-tile__builds-label">{buildCount} builds</span>
                    <span class="class-tile__arrow" aria-hidden="true">→</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <footer class="home-footer">
        <p>Season 12 · Patch 2.6.0.70982 · All data sourced from optimizer_results.db</p>
      </footer>

    </div>
  </main>
</Layout>

<style>
  .home {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: var(--space-lg) 0 var(--space-2xl);
  }

  .home__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    flex: 1;
  }

  /* Hero */
  .hero {
    text-align: center;
    padding-top: var(--space-xl);
  }

  .hero__wordmark {
    font-size: var(--font-size-sm);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .hero__title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .hero__sub {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 520px;
    margin: 0 auto;
  }

  .desktop-only {
    display: none;
  }

  @media (min-width: 768px) {
    .desktop-only {
      display: inline;
    }
  }

  /* Class grid */
  .class-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  @media (min-width: 480px) {
    .class-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .class-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-md);
    }
  }

  @media (min-width: 1100px) {
    .class-grid {
      grid-template-columns: repeat(7, 1fr);
    }
  }

  /* Class tile */
  .class-tile {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.1s ease;
    min-height: 120px;
  }

  @media (min-width: 480px) {
    .class-tile {
      min-height: 160px;
    }
  }

  .class-tile:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), 0 8px 24px rgba(0,0,0,0.4);
    transform: translateY(-1px);
  }

  .class-tile:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), 0 8px 24px rgba(0,0,0,0.4);
  }

  .class-tile:active {
    transform: translateY(0);
  }

  /* Class accent stripe at top */
  .class-tile__accent {
    height: 3px;
    flex-shrink: 0;
  }

  .class-tile--barbarian .class-tile__accent  { background: var(--class-barbarian); }
  .class-tile--druid .class-tile__accent       { background: var(--class-druid); }
  .class-tile--necromancer .class-tile__accent { background: var(--class-necromancer); }
  .class-tile--paladin .class-tile__accent     { background: var(--class-paladin); }
  .class-tile--rogue .class-tile__accent       { background: var(--class-rogue); }
  .class-tile--sorcerer .class-tile__accent    { background: var(--class-sorcerer); }
  .class-tile--spiritborn .class-tile__accent  { background: var(--class-spiritborn); }

  .class-tile__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    flex: 1;
  }

  .class-tile__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .class-tile__name {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    margin: 0;
  }

  .tier-badge {
    font-size: var(--font-size-lg);
    font-weight: 800;
    line-height: 1;
    flex-shrink: 0;
  }

  .class-tile__summary {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .class-tile__summary-line {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .class-tile__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .class-tile__builds-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .class-tile__arrow {
    color: var(--color-primary);
    font-size: var(--font-size-base);
    font-weight: 700;
  }

  /* Footer */
  .home-footer {
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-lg);
  }

  .home-footer p {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
