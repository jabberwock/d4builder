---
import '@/styles/global.css';

interface Props {
  title?: string;
  class?: string;
}

const { title = 'D4Builder — Diablo 4 Build Companion', class: bodyClass } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content="Fast, honest Diablo 4 builds for returning seasonal players. Every number traced to a verified source." />
    <meta name="theme-color" content="#0e0e12" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
